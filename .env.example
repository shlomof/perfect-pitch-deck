# Perfect Pitch Deck Kit — environment variables
# Copy to .env (gitignored) and fill in.
# Most variables are OPTIONAL — the deck builds and deploys without any of them.

# ─── GoHighLevel integration (optional) ────────────────────────────────
# When set, slide 23 captures contact details + choice into your GHL account
# via the /api/lead Cloudflare Pages Function.
# If unset, slide 23 auto-falls-back to static mode using brief.cta.url.
#
# Get these from your GHL Private Integration token (needs `contacts.write`):
#   https://highlevel.stoplight.io/docs/integrations/0443d7d1a4bd0-overview
GHL_API_KEY=
GHL_LOCATION_ID=

# ─── Deck passphrase gate (optional) ───────────────────────────────────
# When set, the published deck is wrapped in staticrypt and viewers
# must enter this passphrase to see it.
DECK_PASSWORD=
DECK_TITLE=
DECK_INSTRUCTIONS=

# Days the unlock persists in the viewer's localStorage. 0 = never persist
# (force re-prompt every visit). Default 30 days.
DECK_REMEMBER_DAYS=30

# ─── Speaker notes encryption (optional) ───────────────────────────────
# When set, speaker notes are AES-encrypted in the published deck and the
# viewer must enter this passphrase before pressing S can open them.
# Independent of DECK_PASSWORD.
NOTES_PASSWORD=

# When `false`, speaker notes are stripped from the published deck entirely
# (use this for public marketing decks where the notes shouldn't be in source).
INCLUDE_NOTES=true

# ─── Cloudflare Pages deploy ───────────────────────────────────────────
# Used by `npm run deploy` and the `/deploy` slash command.
# Project name must match deck.config.json's cloudflare.project_name.
CF_PROJECT=perfect-pitch-deck
